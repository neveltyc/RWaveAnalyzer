$date
    1970-01-01 00:00:00 UTC
$end
$version
    rwave-stimulus
$end
$timescale
	1ps
$end
$scope module counter_fsm $end
$var wire 1 ! tick $end
$var parameter 3 " S_DONE $end
$var parameter 3 # S_HOLD $end
$var parameter 3 $ S_IDLE $end
$var parameter 3 % S_RUN $end
$var reg 16 & accum [15:0] $end
$var reg 1 ' clk $end
$var reg 4 ( const_cfg [3:0] $end
$var reg 8 ) counter [7:0] $end
$var reg 1 * enable $end
$var reg 1 + rst_n $end
$var reg 3 , state [2:0] $end
$upscope $end
$enddefinitions $end
$comment Show the parameter values. $end
$dumpall
